AI_PROVIDER=auto

# Local no-key option for development:
# AI_PROVIDER=ollama
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# For OpenAI-compatible providers:
# AI_PROVIDER=openai_compatible
# AI_PROVIDER_NAME=openrouter
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=***
# AI_MODEL=your_model
# AI_ENABLE_MOCK_FALLBACK=1

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# PostHog analytics. Create a PostHog project and paste its Project API key here.
# US Cloud host: https://us.i.posthog.com
# EU Cloud host: https://eu.i.posthog.com
# Leave NEXT_PUBLIC_POSTHOG_KEY empty to disable analytics locally.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
